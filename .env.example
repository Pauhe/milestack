# Milestack root .env.example
# Copy to `.env` and fill in. Never commit `.env`.

# ── Local rehearsal stack (chainId 31337 / Anvil) ──
# Anvil RPC + backend defaults already match scripts/dev-stack.sh.
# Override only if you run them on different ports/hosts.
# ANVIL_RPC_URL=http://127.0.0.1:8545
# BACKEND_URL=http://127.0.0.1:4100

# ── Rehearsal signer keys ──
# Default to well-known public Anvil keys when unset.
# Provide your own only if you're running a non-standard local devnet.
# REHEARSAL_DEPLOYER_PRIVATE_KEY=0x...
# REHEARSAL_BUYER_PRIVATE_KEY=0x...
# REHEARSAL_SELLER_PRIVATE_KEY=0x...
# REHEARSAL_ARBITER_PRIVATE_KEY=0x...

# ── Factory deployment (scripts/deploy-factory-and-write-manifest.sh) ──
# Required when running the deploy script. Never put a mainnet key here.
# USDC_ADDRESS=0x...
# FEE_RECIPIENT=0x...
# PROTOCOL_FEE_BPS=100
# PRIVATE_KEY=0x...

# ── Coverage enforcement (scripts/check-coverage.mjs) ──
# Set to "hard" in CI to fail on threshold drops.
# COVERAGE_ENFORCEMENT=soft
